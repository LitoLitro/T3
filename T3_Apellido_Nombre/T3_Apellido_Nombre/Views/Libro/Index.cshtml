@model IEnumerable<T3_Apellido_Nombre.Models.Libro>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pt-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Lista de Libros</h2>
        </div>
        <div class="col-6">
        </div>
    </div>

    <br/>

    @if (Model.Count() > 0)
    {
        <table class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th>Titulo</th>
                    <th>Autor</th>
                    <th>Tema</th>
                    <th>Editorial</th>
                    <th>Anio de Publicacion</th>
                    <th>Paginas</th>
                    <th>Categoria</th>
                    <th>Material</th>
                    <th>Copias</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach(var item in Model)
                {
                    <tr>
                        <th width="40%">@item.Titulo</th>
                        <th width="30%">@item.Autor</th>
                        <th width="20%">@item.Tema</th>
                        <th width="20%">@item.Editorial</th>
                        <th width="20%">@item.AnioPublicacion</th>
                        <th width="20%">@item.Paginas</th>
                        <th width="20%">@item.Categoria</th>
                        <th width="20%">@item.Material</th>
                        <th width="20%">@item.Copias</th>
                        <th></th>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No hay registros de Libros</p>
    }

</div>
